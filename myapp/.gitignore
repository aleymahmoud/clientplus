# Ignore Python cache files
__pycache__/
*.py[cod]

# Ignore Django migrations (optional, depending on your workflow)
*/migrations/*.py
!*/migrations/__init__.py

# Ignore local settings files (if you have any)
local_settings.py

# Ignore virtual environment (if using venv)
venv/
.env

# Ignore static files generated by Django
staticfiles/

# Ignore SQLite database file (if using SQLite)
db.sqlite3

# Ignore other database files
FFNT.sqlite

# Ignore IDE-specific files
.idea/
.vscode/
.DS_Store

# Ignore import script if it's not part of the main app
import_data.py